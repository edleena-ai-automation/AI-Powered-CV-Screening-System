        "jsCode": "const applicant = $input.first().json;\n\nconst now = new Date();\n// Pakistan timezone offset (+5)\nconst pkOffset = 5 * 60 * 60 * 1000;\nconst pkNow = new Date(now.getTime() + pkOffset);\n\nlet d = new Date(pkNow);\nd.setDate(pkNow.getDate() + 3);\nwhile (d.getDay() === 0 || d.getDay() === 6) { \n  d.setDate(d.getDate() + 1); \n}\nd.setUTCHours(5, 0, 0, 0); // 10am PKT = 5am UTC\n\nconst end = new Date(d);\nend.setUTCHours(5, 45, 0, 0);\n\nreturn [{ json: {\n  ...applicant,\n  interviewStart: d.toISOString(),\n  interviewEnd: end.toISOString(),\n  interviewDateFormatted: d.toLocaleDateString('en-US', { \n    weekday:'long', year:'numeric', month:'long', day:'numeric', \n    hour:'2-digit', minute:'2-digit', timeZone:'Asia/Karachi' \n  })\n}}];"
