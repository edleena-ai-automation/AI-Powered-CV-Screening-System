    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst safeCvText = (data.cvText || '')\n  .replace(/[\\x00-\\x1F\\x7F]/g, ' ')\n  .replace(/\"/g, '\\\\\"')\n  .trim();\n\nconst safeJobPosition = (data.jobPosition || '').replace(/\"/g, '\\\\\"');\nconst safeFullName = (data.fullName || '').replace(/\"/g, '\\\\\"');\n\nconst body = {\n  model: \"llama-3.3-70b-versatile\",\n  max_tokens: 1200,\n  temperature: 0.3,\n  messages: [\n    {\n      role: \"system\",\n      content: \"You are a professional HR recruitment specialist. You analyze CVs and respond ONLY in valid JSON format. No extra text, no markdown, no backticks. Just raw JSON.\"\n    },\n    {\n      role: \"user\",\n      content: `Job Position: ${safeJobPosition}\\nApplicant: ${safeFullName}\\n\\nCV Content:\\n${safeCvText}\\n\\nAnalyze this CV and respond ONLY in this exact JSON format:\\n{\"decision\": \"ELIGIBLE\" or \"NOT_ELIGIBLE\",\"strengths\": [\"s1\",\"s2\",\"s3\"],\"weaknesses\": [\"w1\",\"w2\",\"w3\"],\"reason\": \"2 sentence reason.\",\"strengthsSummary\": \"Warm 2-3 sentence paragraph.\",\"weaknessesSummary\": \"Polite 2-3 sentence paragraph.\"}`\n    }\n  ]\n};\n\nreturn [{ json: { ...data, groqBody: JSON.stringify(body) } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -640,
        432
      ],
      "id": "d52ec69c-b4bd-480b-967d-b8e4c7c47b35",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const row = $input.first().json;\n\n// Google Drive share URL ko direct download URL mein convert karo\nconst rawUrl = row['Upload CV'] || '';\nlet downloadUrl = '';\n\nif (rawUrl.includes('drive.google.com')) {\n  // Format: https://drive.google.com/open?id=FILE_ID\n  // Ya: https://drive.google.com/file/d/FILE_ID/view\n  let fileId = '';\n  \n  if (rawUrl.includes('/file/d/')) {\n    fileId = rawUrl.split('/file/d/')[1].split('/')[0];\n  } else if (rawUrl.includes('id=')) {\n    fileId = rawUrl.split('id=')[1].split('&')[0];\n  } else if (rawUrl.includes('open?id=')) {\n    fileId = rawUrl.split('open?id=')[1].split('&')[0];\n  }\n  \n  downloadUrl = `https://drive.google.com/uc?export=download&id=${fileId}&confirm=t`;\n} else {\n  downloadUrl = rawUrl;\n}\n\nreturn [{ json: {\n  fullName:    row['Full Name'] || '',\n  email:       row['Email'] || '',\n  phone:       row['Phone Number'] || '',\n  jobPosition: row['Job Position'] || '',\n  cvFileUrl:   row['Upload CV '] || '',\n  submittedAt: row['Timestamp'] || new Date().toISOString()\n}}];"
      },
